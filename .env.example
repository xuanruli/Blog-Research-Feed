# Copy to .env and fill in real values.
# Also configure as GitHub Repository Secrets for the cron workflow.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Filled in after running: python scripts/create_agent.py
ANTHROPIC_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_ENV_ID=env_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Firecrawl --- https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx

# --- X (Twitter) Bearer Token --- https://developer.x.com
# NOTE: pay-per-use; currently 0 credits on the dev account. fetch_x_user
# will return {status: "no_credits"} until topped up.
X_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI Whisper --- podcast transcription (~$0.006/min)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack --- incoming webhook for the daily report
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
