# Copy to .env and fill in real values

# Firecrawl — https://firecrawl.dev
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx

# X (Twitter) Bearer Token — https://developer.x.com
X_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for the Managed Agent session
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Slack incoming webhook for the daily report
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Managed Agent identifiers (created in the Anthropic console)
MANAGED_AGENT_ID=agt_xxxxxxxxxxxxxxxxxxxxxxxx
MANAGED_ENV_ID=env_xxxxxxxxxxxxxxxxxxxxxxxx
